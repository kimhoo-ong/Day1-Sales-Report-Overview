	column 'Target Revenue'
		dataType: double
		lineageTag: 3b1b0057-100b-4e19-a732-4b22e1cc24a6
		summarizeBy: sum
		sourceColumn: target_revenue

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// WHAT: Labels each order as 'Profitable' or 'Loss'.
	/// LOGIC: IF(profit >= 0, 'Profitable', 'Loss'). Derived from the profit column.
	/// USE IN: Conditional formatting on tables (green/red), Loss-Making Orders stacked bar chart (split axis), slicer to isolate loss orders. 28.9% of rows = 'Loss' — a critical business signal to surface.
	column 'Profit Flag' = IF([Profit] >= 0, "Profitable", "Loss")
		dataType: string
		displayFolder: Calculated Columns
		lineageTag: 281107ba-99bd-4590-84aa-4b7952257f46
		summarizeBy: none

	/// WHAT: Gross margin percentage at the individual order line level.
	/// LOGIC: DIVIDE(profit, revenue, 0) * 100. Returns 0 if revenue is zero. Expressed as a number (e.g. 40.7), not a decimal.
	/// USE IN: Conditional formatting on Sales Rep and Product tables, Product treemap color scale, Category bar chart. Use the [Gross Margin %] measure (not this column) in KPI cards and aggregated visuals — this column is for row-level context.
	column 'Margin Pct' = DIVIDE([Profit], [Revenue], 0) * 100
		dataType: double
		formatString: 0.00
		displayFolder: Calculated Columns
		lineageTag: 9e52db90-67e9-47b6-82f3-d6d943d1a6cd
		summarizeBy: average

	/// WHAT: Binary flag (1/0) indicating whether an order hit its revenue target.
	/// LOGIC: IF(revenue >= target_revenue, 1, 0). Used as the numerator in [Target Attainment %] measure.
	/// USE IN: Not for direct display — used internally by the [Target Attainment %] measure. Can be used in CALCULATE filters for custom attainment slices. Only 38.9% of rows = 1.
	column 'Attainment Flag' = IF([Revenue] >= [Target Revenue], 1, 0)
		dataType: int64
		displayFolder: Calculated Columns
		lineageTag: 7c636f7a-d99c-4622-b594-fb28cc9ab5a4
		summarizeBy: sum

	/// WHAT: Human-readable month label for each order.
	/// LOGIC: FORMAT(order_date, 'MMM YYYY') e.g. 'Jan 2024', 'Feb 2024'.
	/// USE IN: Time-series chart X-axis when you need a text label (not a date hierarchy). NOTE: This is a text column — it will sort alphabetically unless you set sort-by to the Month Number column from the Date table. Prefer using Date[Year-Month] from the Date dimension for proper chronological sorting.
	column 'Month Year' = FORMAT([Order Date], "MMM YYYY")
		dataType: string
		displayFolder: Calculated Columns
		lineageTag: 86aac125-270f-4497-9f45-f5ac6114c138
		summarizeBy: none

	/// WHAT: Quarter label for each order.
	/// LOGIC: 'Q' & QUARTER(order_date) — returns 'Q1', 'Q2', 'Q3', 'Q4'.
	/// USE IN: Quarterly slicer, quarterly bar chart grouping. Q4 is the strongest quarter (MYR 3.61M); Q3 is the weakest (MYR 3.36M). Prefer Date[Quarter] from the Date dimension table for cross-table consistency.
	column Quarter = "Q" & QUARTER([Order Date])
		dataType: string
		displayFolder: Calculated Columns
		lineageTag: a20e957b-23f3-497a-8c49-ef01dc507de0
		summarizeBy: none

	/// WHAT: Classifies each order into a deal size tier.
	/// LOGIC: SWITCH(TRUE(), revenue < 2000, 'Small', revenue <= 10000, 'Mid', 'Large').
	/// USE IN: Deal size distribution bar chart, slicer for filtering by deal tier, Sales Rep analysis to understand rep deal-size mix. Useful for identifying reps who rely on small-deal volume vs those who close large strategic deals.
	column 'Deal Size Band' = SWITCH(TRUE(), [Revenue] < 2000, "Small", [Revenue] <= 10000, "Mid", "Large")
		dataType: string
		displayFolder: Calculated Columns
		lineageTag: 5bfd5405-2468-4d44-b3eb-037f5696cc93
		summarizeBy: none

	column ProductKey = [Product Name] & "|" & [Category]
		dataType: string
		isHidden
		displayFolder: Keys
		lineageTag: cf8d5ace-db0d-473b-bb88-7c352fd8c400
		summarizeBy: none

