		dataType: string
		lineageTag: f406ede6-922f-4e73-a74d-d3b3b5586321
		summarizeBy: none
		sourceColumn: category

		annotation SummarizationSetBy = Automatic

	column Region
		dataType: string
		isHidden
		lineageTag: b71dd18b-c524-475c-85a0-b7aecbb0f0c1
